{
  "name": "propeller",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/nest-static-export.mjs",
    "dev": "next dev",
    "start": "serve out",
    "deploy": "pnpm run build && wrangler deploy",
    "upload": "pnpm run build && wrangler versions upload",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check .",
    "lint:fix": "biome check src --write",
    "check:assets": "bash scripts/check-assets.sh",
    "optimize:images": "f() { webp=\"${1%.*}.webp\"; magick \"$1\" -resize 1200x1200\\> -quality 82 \"$webp\" && rm \"$1\" && echo \"Converted $1 → $webp (original removed)\"; }; f"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "10.3.14",
    "fumadocs-ui": "16.6.8",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "json-schema-typed": "^8.0.2",
    "openapi-types": "^12.1.3",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.5.1"
}
